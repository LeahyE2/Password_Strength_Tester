import string

def print_Strength(password):
    n = len(password)

    hasLower = False
    hasUpper = False
    hasDigit = False
    specialChar = False
    # Define normal characters (alphanumeric + space)
    normalChars = string.ascii_letters + string.digits + " "

    # Checks the password requirements
    for char in password:
        if char.islower():
            hasLower = True
        elif char.isupper():
            hasUpper = True
        elif char.isdigit():
            hasDigit = True
        elif char not in normalChars:
            specialChar = True

    #sStrength criteria
    strength = "Weak"
    requirements = [
        ("Length >= 8", n >= 8),
        ("Length >= 12", n >= 12),
        ("Lowercase letter", hasLower),
        ("Uppercase letter", hasUpper),
        ("Digit", hasDigit),
        ("Special character", specialChar),
    ]

    met_requirements = [desc for desc, condition in requirements if condition]
    unmet_requirements = [desc for desc, condition in requirements if not condition]

    # Determine strength level
    if n >= 12 and all([hasLower, hasUpper, hasDigit, specialChar]):
        strength = "Strong"
    elif n >= 8 and all([hasLower, hasUpper, hasDigit]):
        strength = "Moderate"
    elif n >= 6:
        strength = "Weak"
    else:
        strength = "Very Weak"

    # Print detailed report
    print("\nPassword Strength Analysis:")
    print(f"- Final verdict: {strength}")
    print(f"- Length: {n} characters")

    print("\nMet requirements:")
    for req in met_requirements:
        print(f"✓ {req}")

    if unmet_requirements:
        print("\nMissing requirements:")
        for req in unmet_requirements:
            print(f"✗ {req}")


if __name__ == "__main__":
    try:
        password = input("Enter password to test: ")
        print_Strength(password)
    except KeyboardInterrupt:
        print("\n\nOperation cancelled by user")
    except Exception as e:
        print(f"An error occurred: {str(e)}")











